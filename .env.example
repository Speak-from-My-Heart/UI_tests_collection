# Этот файл — шаблон. Скопируй его в .env и заполни своими значениями.
# .env добавлен в .gitignore — он никогда не попадёт в репозиторий.

# Telegram
TG_TOKEN=your_bot_token_here
TG_CHAT_ID=your_chat_id_here

# Креды приложения (только для локальной отладки)
# В GitHub Actions они берутся из Secrets автоматически
APP_EMAIL=qa+k+brandE@elibrium.io
APP_PASSWORD=your_password_here
